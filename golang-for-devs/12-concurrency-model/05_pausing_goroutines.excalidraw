      "lineHeight": 1.25,
      "hasTextLink": false,
      "link": null
    },
    {
      "id": "ydL3aQ3Uamt2VfDWBgCtO",
      "type": "text",
      "x": -1042.906167317643,
      "y": 1764.9593325115916,
      "width": 672.227783203125,
      "height": 540,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "#fcc2d7",
      "fillStyle": "solid",
      "strokeWidth": 4,
      "strokeStyle": "solid",
      "roughness": 0,
      "opacity": 100,
      "groupIds": [
        "4b8cWn8lWICITG_GOi9nT"
      ],
      "frameId": null,
      "index": "b0U",
      "roundness": null,
      "seed": 1186142503,
      "version": 937,
      "versionNonce": 1134686215,
      "isDeleted": false,
      "boundElements": [],
      "updated": 1776543078920,
      "locked": false,
      "text": "Search Order:\n1. Internal GC and Trace work\n2. Global queue fairness check\n        - Every 61st schedule call, the\n           scheduler grabs the next goroutine\n           from the global run queue\n           (schedt.runq)\n3. Local up-next slot (p.runnext)\n4. Local run queue (p.runq)\n5. Global run queue (schedt.runq)\n6. Network Poller\n7. Work Stealing - other P's runq's",
      "fontSize": 36,
      "fontFamily": 6,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "Search Order:\n1. Internal GC and Trace work\n2. Global queue fairness check\n        - Every 61st schedule call, the\n           scheduler grabs the next goroutine\n           from the global run queue\n           (schedt.runq)\n3. Local up-next slot (p.runnext)\n4. Local run queue (p.runq)\n5. Global run queue (schedt.runq)\n6. Network Poller\n7. Work Stealing - other P's runq's",
      "autoResize": true,
      "lineHeight": 1.25,
      "hasTextLink": false,
      "link": null
    },
