      "versionNonce": 468986553,
      "isDeleted": false,
      "boundElements": [],
      "updated": 1777137385352,
      "locked": false,
      "text": "- M starts a \"spinning\" loop, checking \n   queues and trying to find a new G to run\n- M goes to sleep after a while\n- Detach M and P (remove pointers)\n- Put P on schedt.pidle",
      "fontSize": 36,
      "fontFamily": 6,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "- M starts a \"spinning\" loop, checking \n   queues and trying to find a new G to run\n- M goes to sleep after a while\n- Detach M and P (remove pointers)\n- Put P on schedt.pidle",
      "autoResize": true,
      "lineHeight": 1.25,
      "hasTextLink": false,
      "link": null
    },
