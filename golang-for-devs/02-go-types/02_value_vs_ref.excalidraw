    {
      "id": "mTH-fc80Eegl3yTf_7OQB",
      "type": "text",
      "x": -42.91546630859375,
      "y": -17.776466681208547,
      "width": 334.31964111328125,
      "height": 450,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 2,
      "strokeStyle": "solid",
      "roughness": 0,
